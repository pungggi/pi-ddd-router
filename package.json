{
  "name": "pi-ddd-router",
  "version": "0.1.0",
  "private": true,
  "description": "Combined DDD workflow enforcement + Auggie sub-agent routing for Pi. One extension, zero duplicated wiring. Monorepo-only — compose pi-ddd + pi-auggie-router in your own extension, or use this package directly in a workspace.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "extension.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "node --test --test-reporter=spec --import tsx tests/**/*.test.ts"
  },
  "keywords": [
    "pi",
    "pi.dev",
    "pi-extension",
    "ddd",
    "domain-driven-design",
    "auggie",
    "router",
    "sub-agent",
    "mcp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  },
  "peerDependencies": {
    "pi-auggie-router": "^1.0.0",
    "pi-ddd": ">=0.2.0 <1.0.0",
    "@mariozechner/pi-coding-agent": ">=0.70.6"
  },
  "devDependencies": {
    "pi-auggie-router": "file:../pi-auggie-router",
    "pi-ddd": "file:../pi-ddd",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungggi/pi-ddd-router.git"
  },
  "homepage": "https://github.com/pungggi/pi-ddd-router#readme",
  "bugs": {
    "url": "https://github.com/pungggi/pi-ddd-router/issues"
  }
}
